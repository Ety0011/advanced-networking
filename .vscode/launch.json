{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "name": "C: dnslookup",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/out/build/clang/dnslookup",
      "args": [
        "-s",
        "8.8.8.8",
        "google.com"
      ],
      "stopAtEntry": false,
      "cwd": "${fileDirname}",
      "environment": [],
      "externalConsole": false,
      "MIMode": "lldb",
    },
    {
        "name": "Python: Current File",
        "type": "python",
        "request": "launch",
        "program": "${file}",
        "console": "integratedTerminal",
        "cwd": "${fileDirname}",
        "args": [
            "--draw",
            "topology.yaml"
        ]
    }
  ]
}
